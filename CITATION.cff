    family-names: Karauda
  - name: "The AI Usage Scale contributors"
version: 1.1.0-draft
date-released: 2026-07-17
license: CC-BY-4.0
url: "https://usagescale.org"
repository-code: "https://github.com/karauda/ai-usage-scale"
keywords:
  - AI disclosure
  - AI transparency
  - generative AI
  - content provenance
  - AI attribution
  - open standard
