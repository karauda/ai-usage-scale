---
import Base from '../../layouts/Base.astro';
import TranslationNotice from '../../components/TranslationNotice.astro';
import { localeParams, getLocale, levelsIn, localePath } from '../../lib/i18n';

export const getStaticPaths = localeParams;

const { lang } = Astro.props;
const t = getLocale(lang);
const LEVELS = levelsIn(lang);
const L = (p: string) => localePath(lang, p);
---

<Base
  lang={lang}
  path="/scale"
  title={`${t.ui.scalePage.h1} — AI Usage Scale`}
  description={t.principle}
  card="scale"
  breadcrumb={[[t.ui.nav.scale, '/scale']]}
  schema={[
    {
      '@type': 'WebPage',
      '@id': `https://usagescale.org${L('/scale')}#page`,
      name: t.ui.scalePage.h1,
      inLanguage: lang,
      mainEntity: { '@id': 'https://usagescale.org/#scale' },
      isPartOf: { '@id': 'https://usagescale.org/#site' },
    },
  ]}
>
  <TranslationNotice lang={lang} path="/scale" />

  <header class="top prose">
    <p class="label">{t.ui.scalePage.eyebrow}</p>
    <h1>{t.ui.scalePage.h1}</h1>
    <p class="standfirst">{t.principle}</p>
  </header>

  <section class="axis">
    <div>
      <p class="label">{t.ui.scalePage.measures}</p>
      <p>{t.axis.measures}</p>
    </div>
    <div>
      <p class="label">{t.ui.scalePage.refuses}</p>
      <p>{t.axis.doesNotMeasure}</p>
    </div>
  </section>

  <div class="sheet">
    {
      LEVELS.map((l) => (
        <article class="lv" id={`level-${l.id}`}>
          <div class="lv-mark">
            <span class="lv-big">{l.id}</span>
            <span class="tick-row" aria-hidden="true">
              {[0, 1, 2, 3, 4, 5].map((i) => <span class="tick" data-on={i === l.id ? '' : undefined} />)}
            </span>
          </div>
          <div class="lv-body">
            <h2><a href={L(`/${l.id}`)}>{l.name}</a></h2>
            <p class="lv-one">{l.oneLine}</p>
            <p class="lv-def">{l.definition}</p>
            <p class="lv-eg">
              <span class="label">{t.ui.scalePage.forInstance}</span>
              {l.examples[0]}
            </p>
            <p class="lv-more"><a href={L(`/${l.id}`)}>{t.ui.scalePage.more}</a></p>
          </div>
        </article>
      ))
    }
  </div>

  <aside class="closing prose">
    <h2>{t.ui.scalePage.closingH}</h2>
    <p>{t.ui.scalePage.closingA}</p>
    <p>{t.ui.scalePage.closingB}</p>
    <p><a href={L('/find-your-level')} class="cta">{t.ui.hero.cta}</a></p>
  </aside>
</Base>

<style>
  .top { margin: 3rem 0 2.5rem; }
  .top h1 { font-size: clamp(2.25rem, 6vw, 3.25rem); letter-spacing: -0.02em; margin: 0.4rem 0 0.75rem; }

  .axis {
    display: grid;
    gap: 2rem;
    padding: 2rem 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    margin-bottom: 1rem;
  }
  .axis p:not(.label) { margin: 0.5rem 0 0; color: var(--ink-mid); font-size: 1.0625rem; }

  .lv {
    display: grid;
    gap: 1.25rem;
    padding: 2.25rem 0;
    border-bottom: 1px solid var(--rule-soft);
  }
  /* Greenbar: the stripe that machine output was printed on, for humans to read. */
  .lv:nth-child(odd) { background: var(--band); margin-inline: calc(var(--gutter) * -1); padding-inline: var(--gutter); }
  .lv-mark { display: flex; align-items: center; gap: 1rem; }
  .lv-big { font-family: var(--mono); font-weight: 600; font-size: 2.75rem; line-height: 1; }

  .lv-body h2 {
    margin: 0 0 0.6rem;
    font-family: var(--mono);
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .lv-body h2 a { text-decoration: none; }
  .lv-body h2 a:hover { color: var(--accent); }
  .lv-one { font-size: 1.25rem; margin: 0 0 1rem; }
  .lv-def { color: var(--ink-mid); margin: 0 0 1.25rem; font-size: 1.0625rem; }
  .lv-eg { margin: 0 0 1rem; font-style: italic; color: var(--ink-mid); }
  .lv-eg .label { display: block; font-style: normal; margin-bottom: 0.25rem; }
  .lv-more { margin: 0; font-family: var(--mono); font-size: 0.8125rem; }
  .lv-more a { color: var(--ink-mid); text-decoration: none; }
  .lv-more a:hover { color: var(--accent); }

  .closing { margin-top: 4rem; }
  .closing p { color: var(--ink-mid); }
  .cta {
    display: inline-block;
    margin-top: 1rem;
    font-family: var(--mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.75rem 1.25rem;
    background: var(--ink);
    color: var(--paper);
    border: 1px solid var(--ink);
  }
  .cta:hover { background: var(--accent); border-color: var(--accent); color: #fff; }
</style>
